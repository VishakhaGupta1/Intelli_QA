### QA Intelligence Platform - example environment variables

# Claude AI (prefer Grok by default)
GROK_API_KEY=your_grok_api_key_here
# Grok endpoint override if needed
GROK_URL=https://api.grok.ai/v1/generate
# Optionally provide an Anthropic/Claude key as a fallback (not required)
ANTHROPIC_API_KEY=

# MongoDB
MONGO_URI=
MONGO_DB_NAME=qa_platform
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_AUTH_SOURCE=qa_platform
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_USERNAME=qa_platform_app
MONGO_PASSWORD=change-me

# Application under test
BASE_URL=http://localhost:4000

# Dashboard API
PORT=3001
# Dashboard API CORS allowlist (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=change-me-to-a-long-random-string
# Client secret used to mint JWTs; must be a strong random string of at least 32 characters
CLIENT_SECRET=change-me-to-a-long-random-string
GRAFANA_ADMIN_PASSWORD=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1h
METRICS_ALLOWED_SUBNETS=127.0.0.1,::1,172.16.0.0/12

# MongoDB pooling/timeouts
MONGO_MAX_POOL_SIZE=20
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000

# React app API base URL
VITE_API_BASE_URL=http://localhost:3001/api

# CI flag (set to true in CI environments)
HEADLESS=true

# Use mock AI responses (for local development without an API key)
USE_MOCK=true

# Allow falling back to mock AI output when no LLM provider is configured
ALLOW_MOCK_FALLBACK=true

# Selenium remote endpoint for browser-pinned CI / dockerized runs
SELENIUM_REMOTE_URL=http://127.0.0.1:4444/wd/hub

# Backups
BACKUP_DIR=/backups
